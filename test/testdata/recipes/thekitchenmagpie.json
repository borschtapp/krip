  "recipeYield": 8,
  "recipeIngredient": [
    "16 ounces of canned salmon (drained)",
    "1 cup seasoned fine breadcrumbs",
    "½ cup onion (finely chopped)",
    "1 tsp dill weed",
    "1/2 cup milk",
    "2 large eggs (beaten)",
    "1 tablespoon lemon juice",
    "½ tsp salt",
    "¼ tsp black pepper"
  ],
  "recipeInstructions": [
    {
      "text": "Preheat your oven to 375 °F. Grease a baking sheet and set aside.",
      "url": "https://www.thekitchenmagpie.com/salmon-loaf/#wprm-recipe-80439-step-0-0"
    },
    {
      "text": "Drain the salmon well and if desired, remove any skin and bones from the salmon. You can leave them in, some people love those the best! They will bake right in, don't worry.",
      "url": "https://www.thekitchenmagpie.com/salmon-loaf/#wprm-recipe-80439-step-0-1"
    },
    {
      "text": "Flake the salmon with a fork and then mix with the breadcrumbs, onion, milk, dill, eggs, lemon juice, salt and pepper.",
      "url": "https://www.thekitchenmagpie.com/salmon-loaf/#wprm-recipe-80439-step-0-2"
    },
    {
      "text": "With clean hands, shape into a loaf on the greased baking sheet.",
      "url": "https://www.thekitchenmagpie.com/salmon-loaf/#wprm-recipe-80439-step-0-3"
    },
    {
      "text": "Bake for 40-50 minutes OR until nicely browned AND reaches an internal temperature of at least 165 °F.",
      "url": "https://www.thekitchenmagpie.com/salmon-loaf/#wprm-recipe-80439-step-0-4"
    },
    {
      "text": "Let cool for 5 minutes, then slice and serve. Garnish with fresh parsley and lemon wedges. This is excellent with lemon juice squeezed on top!",
      "url": "https://www.thekitchenmagpie.com/salmon-loaf/#wprm-recipe-80439-step-0-5"
    }
  ],
