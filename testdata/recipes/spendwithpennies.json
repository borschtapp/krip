  "recipeIngredient": [
    "¾ cup all-purpose flour",
    "½ cup sugar",
    "½ cup unsweetened cocoa powder",
    "1 ½ teaspoons baking powder",
    "⅔ cup milk",
    "2 tablespoons vegetable oil",
    "1 teaspoon vanilla",
    "⅔ cup brown sugar (packed)",
    "¼ cup cocoa powder",
    "¼ cup miniature semisweet chocolate chips",
    "1 ¼ cups very hot water"
  ],
  "recipeInstructions": [
    {
      "text": "Preheat oven to 350°F.",
      "url": "https://www.spendwithpennies.com/gooey-chocolate-pudding-cake/#wprm-recipe-135714-step-0-0"
    },
    {
      "text": "In a 2 qt casserole dish, combine flour, white sugar, cocoa powder, and baking powder.",
      "url": "https://www.spendwithpennies.com/gooey-chocolate-pudding-cake/#wprm-recipe-135714-step-0-1"
    },
    {
      "text": "Add milk and oil, and vanilla. Stir until well mixed.",
      "url": "https://www.spendwithpennies.com/gooey-chocolate-pudding-cake/#wprm-recipe-135714-step-0-2"
    },
    {
      "text": "In a small bowl, combine brown sugar, cocoa powder and chocolate chips. Sprinkle over cake batter. DO NOT STIR. Pour hot water over top.",
      "url": "https://www.spendwithpennies.com/gooey-chocolate-pudding-cake/#wprm-recipe-135714-step-0-3"
    },
    {
      "text": "Bake for 30-35 minutes or until the top looks cooked. Serve warm (with ice cream if desired).",
      "url": "https://www.spendwithpennies.com/gooey-chocolate-pudding-cake/#wprm-recipe-135714-step-0-4"
    }
  ],
